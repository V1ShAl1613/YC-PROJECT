# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use SQLite in development
DATABASE_URL=

# ── Vector Store ──────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss.index
FAISS_META_PATH=./data/faiss_meta.pkl

# ── Data Source API Tokens ────────────────────────────────────────────────────
# Get free token at https://www.courtlistener.com/register/
COURTLISTENER_API_TOKEN=

# Get token at https://api.indiankanoon.org
INDIAN_KANOON_API_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
